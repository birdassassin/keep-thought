{
  "version": 2,
  "name": "keep-thought-demos",
  "builds": [
    {
      "src": "demo-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/demo-app/dist/$1"
    }
  ],
  "github": {
    "enabled": false
  }
}
